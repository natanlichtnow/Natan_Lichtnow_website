      body {
      background: linear-gradient(180deg, #080f08 0%, #0a1810 50%, #080d08 100%) !important;
    }

    .mh-page {
      --mh-accent: #00e676;
      --mh-accent-soft: rgba(0, 230, 118, 0.12);
      --mh-accent-strong: rgba(0, 230, 118, 0.32);
      --mh-accent-glow: rgba(0, 230, 118, 0.2);
      --mh-secondary: #00bcd4;
      --mh-text: #d8f0e0;
      --mh-text-muted: #6a9878;
      --mh-panel: rgba(12, 28, 18, 0.72);
      --mh-panel-strong: rgba(8, 22, 12, 0.94);
      --mh-border: rgba(0, 230, 118, 0.14);
      position: relative;
      overflow-x: hidden;
    }

    .mh-page .c-topbar { background: rgba(4, 12, 7, 0.92) !important; border-bottom: 1px solid rgba(0, 230, 118, 0.1); }


    .mh-hero { position: relative; min-height: 52vh; display: flex; align-items: center; padding: 4rem 1.5rem; }
    .mh-hero__inner { display:flex; gap:2rem; align-items:center; width:100%; max-width:1200px; margin:0 auto; }
    .mh-hero__inner { position: relative; z-index: 10 }
    .mh-hero__copy { flex:1 }
    .mh-title { font-family: 'Rajdhani', sans-serif; font-size: clamp(2rem, 5vw, 3rem); color: #e8f5ea; margin:0 0 0.8rem }
    .mh-lead { color:var(--mh-text-muted); max-width:640px }
    .mh-hero__img { width:420px; border-radius:12px }

    /* Flow-specific hero: center copy and enlarge title */
    .mh-hero--flow { margin: 0 !important; padding: 0 !important; }
    .mh-hero--flow .mh-hero__inner { flex-direction: column; text-align: center; gap: 1rem }
    .mh-hero--flow .mh-hero__copy { width: 100%; }
    .mh-hero--flow .mh-title { font-size: clamp(3rem, 9vw, 6rem); }
    .mh-hero--flow .mh-lead { margin: 0 auto; max-width: 820px }

    .mh-chapters { max-width:1200px; margin:2.5rem auto; padding:0 1.5rem }
    .mh-chapter { padding: 2rem 0; border-bottom: 1px solid rgba(0, 230, 118, 0.06); }
    /* Soften separators and remove harsh line under hero */
    .mh-chapter { border-bottom: 1px solid rgba(0, 230, 118, 0.03); }
    .mh-hero { border-bottom: none !important; }
    .mh-chapter__title { font-family: 'Rajdhani', sans-serif; font-size: clamp(1.4rem, 3.5vw, 2rem); font-weight:700; color:#c0e0c8; margin:0 0 1rem }
    .mh-split { display:grid; grid-template-columns:1fr 1fr; gap:2.5rem; align-items:center }
    .mh-split__text { background: rgba(8,40,20,0.45); padding:1.4rem; border-left:3px solid rgba(0,230,118,0.35); border-radius:10px; color:#c8f0d8 }
    .mh-split__media iframe, .mh-split__media img { width:100%; border-radius:10px }

    .mh-img-caption { font-family: 'Orbitron', sans-serif; font-size: 0.55rem; letter-spacing: 0.22em; text-transform: uppercase; color: #3a6848; text-align:center; margin-top:0.6rem }
    .mh-cta { display:inline-flex !important; align-items:center; justify-content:center; gap:0.5rem; margin-top:0.8rem; padding:0.75rem 1rem !important; background:var(--mh-accent) !important; color:#05210a !important; border-radius:10px; font-weight:700; text-decoration:none; border: none !important; cursor: pointer; box-shadow: 0 8px 20px rgba(0,0,0,0.28); transition: transform 140ms ease, box-shadow 140ms ease; min-width:220px; z-index:12 }
    .mh-cta:hover { transform: translateY(-3px); box-shadow: 0 14px 32px rgba(0,0,0,0.34) }
    .mh-cta:focus { outline: 3px solid rgba(0,230,118,0.18); outline-offset: 3px }

    @media (max-width:700px) { .mh-split { grid-template-columns:1fr } .mh-hero__img { width: 220px } }
    /* Animated ambient blobs & stars (from history page) */
    .mh-hero__bg { position: absolute; inset: 0; z-index: 0; background: radial-gradient(ellipse at 25% 25%, rgba(0, 80, 40, 0.55) 0%, transparent 45%), radial-gradient(ellipse at 75% 15%, rgba(0, 60, 100, 0.55) 0%, transparent 40%), radial-gradient(ellipse at 50% 5%, rgba(0, 100, 80, 0.35) 0%, transparent 38%), linear-gradient(180deg, #040a06 0%, #061012 40%, #040a06 100%); }
    .mh-hero__blob { position: absolute; border-radius: 50%; pointer-events: none; filter: blur(100px); opacity: 0; will-change: transform, opacity; }
    .mh-hero__blob--1 { width: 45vw; height: 45vw; top: -10%; left: -12%; background: radial-gradient(circle, rgba(0, 230, 118, 0.22) 0%, transparent 70%); animation: mh-blob-drift-1 18s ease-in-out infinite alternate; }
    .mh-hero__blob--2 { width: 38vw; height: 38vw; top: 15%; right: -8%; background: radial-gradient(circle, rgba(0, 188, 212, 0.2) 0%, transparent 70%); animation: mh-blob-drift-2 22s ease-in-out infinite alternate; }
    .mh-hero__blob--3 { width: 30vw; height: 30vw; bottom: 10%; left: 30%; background: radial-gradient(circle, rgba(74, 0, 224, 0.16) 0%, transparent 70%); animation: mh-blob-drift-3 26s ease-in-out infinite alternate; }
    @keyframes mh-blob-drift-1 { 0% { transform: translate(0,0) scale(1); opacity:0.6 } 33% { transform: translate(8vw,5vh) scale(1.12); opacity:0.75 } 66% { transform: translate(-3vw,10vh) scale(0.95); opacity:0.55 } 100% { transform: translate(5vw,-3vh) scale(1.08); opacity:0.7 } }
    @keyframes mh-blob-drift-2 { 0% { transform: translate(0,0) scale(1); opacity:0.5 } 33% { transform: translate(-6vw,8vh) scale(1.1); opacity:0.7 } 66% { transform: translate(4vw,-4vh) scale(0.92); opacity:0.45 } 100% { transform: translate(-5vw,6vh) scale(1.06); opacity:0.65 } }
    @keyframes mh-blob-drift-3 { 0% { transform: translate(0,0) scale(1); opacity:0.45 } 33% { transform: translate(6vw,-6vh) scale(1.14); opacity:0.6 } 66% { transform: translate(-5vw,3vh) scale(0.9); opacity:0.4 } 100% { transform: translate(3vw,8vh) scale(1.05); opacity:0.55 } }
    .mh-hero__stars { position: absolute; inset: 0; z-index: 1; background-image: radial-gradient(circle, rgba(255,255,255,0.85) 1px, transparent 1px), radial-gradient(circle, rgba(255,255,255,0.55) 1px, transparent 1px), radial-gradient(circle, rgba(200,240,220,0.5) 1px, transparent 1px), radial-gradient(circle, rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 220px 220px, 170px 170px, 310px 310px, 140px 140px; background-position: 0 0, 80px 50px, 140px 90px, 55px 130px; opacity: 0.25 }
    /* Full-page stars layer */
    .mh-page__stars { position: absolute; inset: 0; z-index: 0; pointer-events: none; background-image: radial-gradient(circle, rgba(255,255,255,0.85) 1px, transparent 1px), radial-gradient(circle, rgba(255,255,255,0.55) 1px, transparent 1px), radial-gradient(circle, rgba(200,240,220,0.5) 1px, transparent 1px), radial-gradient(circle, rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 220px 220px, 170px 170px, 310px 310px, 140px 140px; background-position: 0 0, 80px 50px, 140px 90px, 55px 130px; opacity: 0.18 }

    /* Full-page ambient background (story) */
    .mh-page::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 0;
      background: radial-gradient(ellipse at 0% 15%, rgba(0, 60, 30, 0.28) 0%, transparent 30%), radial-gradient(ellipse at 100% 40%, rgba(0, 50, 80, 0.22) 0%, transparent 28%), radial-gradient(ellipse at 50% 75%, rgba(0, 60, 30, 0.2) 0%, transparent 30%);
      pointer-events: none;
    }

    .mh-story__blob { position: absolute; border-radius: 50%; pointer-events: none; filter: blur(120px); opacity: 0; will-change: transform, opacity; z-index: 0; }
    .mh-story__blob--a { width: 50vw; height: 50vw; top: 5%; left: -15%; background: radial-gradient(circle, rgba(0, 230, 118, 0.18) 0%, transparent 70%); animation: mh-story-blob-a 28s ease-in-out infinite alternate; }
    .mh-story__blob--b { width: 42vw; height: 42vw; top: 25%; right: -10%; background: radial-gradient(circle, rgba(0, 188, 212, 0.16) 0%, transparent 70%); animation: mh-story-blob-b 32s ease-in-out infinite alternate; }
    .mh-story__blob--c { width: 36vw; height: 36vw; top: 50%; left: 20%; background: radial-gradient(circle, rgba(0, 0, 255, 0.12) 0%, transparent 70%); animation: mh-story-blob-c 24s ease-in-out infinite alternate; }
    .mh-story__blob--d { width: 44vw; height: 44vw; top: 72%; right: -5%; background: radial-gradient(circle, rgba(74, 0, 224, 0.13) 0%, transparent 70%); animation: mh-story-blob-d 30s ease-in-out infinite alternate; }
    .mh-story__blob--e { width: 38vw; height: 38vw; top: 90%; left: -8%; background: radial-gradient(circle, rgba(0, 200, 83, 0.15) 0%, transparent 70%); animation: mh-story-blob-e 26s ease-in-out infinite alternate; }

    @keyframes mh-story-blob-a { 0% { transform: translate(0,0) scale(1); opacity:0.5 } 25% { transform: translate(10vw,4vh) scale(1.15); opacity:0.65 } 50% { transform: translate(3vw,12vh) scale(0.9); opacity:0.45 } 75% { transform: translate(-5vw,8vh) scale(1.1); opacity:0.6 } 100% { transform: translate(6vw,-2vh) scale(1.02); opacity:0.52 } }
    @keyframes mh-story-blob-b { 0% { transform: translate(0,0) scale(1); opacity:0.4 } 25% { transform: translate(-8vw,6vh) scale(1.12); opacity:0.58 } 50% { transform: translate(5vw,-3vh) scale(0.88); opacity:0.35 } 75% { transform: translate(-3vw,10vh) scale(1.08); opacity:0.55 } 100% { transform: translate(7vw,4vh) scale(0.95); opacity:0.42 } }
    @keyframes mh-story-blob-c { 0% { transform: translate(0,0) scale(1); opacity:0.38 } 25% { transform: translate(7vw,-5vh) scale(1.18); opacity:0.52 } 50% { transform: translate(-4vw,8vh) scale(0.85); opacity:0.32 } 75% { transform: translate(6vw,3vh) scale(1.1); opacity:0.5 } 100% { transform: translate(-6vw,-4vh) scale(0.98); opacity:0.4 } }
    @keyframes mh-story-blob-d { 0% { transform: translate(0,0) scale(1); opacity:0.35 } 25% { transform: translate(-9vw,-4vh) scale(1.1); opacity:0.5 } 50% { transform: translate(4vw,7vh) scale(0.92); opacity:0.3 } 75% { transform: translate(-2vw,-6vh) scale(1.14); opacity:0.48 } 100% { transform: translate(8vw,3vh) scale(1.0); opacity:0.38 } }
    @keyframes mh-story-blob-e { 0% { transform: translate(0,0) scale(1); opacity:0.42 } 25% { transform: translate(6vw,5vh) scale(1.16); opacity:0.58 } 50% { transform: translate(-7vw,-3vh) scale(0.88); opacity:0.36 } 75% { transform: translate(3vw,9vh) scale(1.06); opacity:0.54 } 100% { transform: translate(-4vw,2vh) scale(0.96); opacity:0.44 } }

    /* remove flat border between hero and content */
    .mh-chapters { margin-top: 0; }
    .mh-chapters .mh-chapter:first-child { border-top: none; }

