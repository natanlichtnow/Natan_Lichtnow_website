/* Garante que o badge de ano nunca estique em flex containers */
.mh-year {
  flex: 0 0 auto !important;
  align-self: flex-start !important;
}
@media (max-width: 800px) {
  .mh-row--wrap.u-gap-lg.u-align-center.u-mt-xs.u-mb-xs {
    justify-content: center !important;
  }
  .mh-row--wrap.u-gap-lg.u-align-center.u-mt-xs.u-mb-xs img[src*="boomfest.jpg"] {
    margin-left: auto !important;
    margin-right: auto !important;
    display: block !important;
  }
}
@media (max-width: 800px) {
  .mh-row--chapter22 {
    flex-direction: column !important;
    align-items: stretch !important;
  }
  .mh-img-wrap--twitchcon-responsive {
    justify-content: center !important;
    margin: 1.5rem 0 0 0 !important;
    max-width: 100vw !important;
  }
  .mh-img--twitchcon-responsive {
    max-width: 90vw !important;
    width: 100% !important;
    margin-left: auto !important;
    margin-right: auto !important;
    display: block !important;
  }
}
@media (min-width: 801px) {
  .mh-row--chapter22 {
    flex-direction: row !important;
  }
  .mh-img-wrap--twitchcon-responsive {
    align-items: center !important;
    margin: 0 !important;
    max-width: none !important;
  }
  .mh-img--twitchcon-responsive {
    max-width: 40vw !important;
    width: 260px !important;
  }
}
/* Box largura igual ao divisor de seção */
.u-maxw-divider { max-width: 1100px !important; margin-left: auto !important; margin-right: auto !important; }
/* ========== UTILITÁRIOS BEM/OOCSS ========== */
.u-gap-xxl { gap: 2.5rem !important; }
.u-gap-lg { gap: 1.5rem !important; }
.u-gap-md { gap: 1rem !important; }
.u-gap-xs { gap: 0.5rem !important; }
.u-mt-xl { margin-top: 2.5rem !important; }
.u-mb-md { margin-bottom: 1rem !important; }
.u-mt-xs { margin-top: 0.5rem !important; }
.u-mb-xs { margin-bottom: 0.5rem !important; }
.u-mt-md { margin-top: 1rem !important; }
.u-mt-lg { margin-top: 1.5rem !important; }
.u-w-full { width: 100% !important; }
.u-w-md { width: 260px !important; }
.u-w-lg { width: 340px !important; }
.u-maxw-xl { max-width: 900px !important; }
.u-maxw-40vw { max-width: 40vw !important; }
.u-maxw-90vw { max-width: 90vw !important; }
.u-minw-lg { min-width: 420px !important; }
.u-h-auto { height: auto !important; }
.u-flex-col { display: flex !important; flex-direction: column !important; }
.u-flex-center { display: flex !important; align-items: center !important; justify-content: center !important; }
.u-align-center { align-items: center !important; }
.u-align-stretch { align-items: stretch !important; }
.u-justify-center { justify-content: center !important; }
.u-inline-block { display: inline-block !important; }
.u-text-center { text-align: center !important; }
.u-fs-md { font-size: 1.08em !important; }
.u-pr-md { padding-right: 1.25rem !important; }
.u-maxw-unset { max-width: none !important; }
.mh-img--rounded { border-radius: 14px !important; object-fit: cover !important; }
.mh-row { display: flex !important; }
.mh-row--nowrap { flex-wrap: nowrap !important; }
.mh-row--wrap { flex-wrap: wrap !important; }
.mh-img-wrap { display: flex !important; align-items: center !important; justify-content: center !important; }
/* ========================================================================== */
/* NATAN LICHTNOW - INTERNAL PAGES                                             */
/* Distinct atmospheres for paraglider, music, and development branches        */
/* ========================================================================== */

:root {
  --page-bg: #09101f;
  --page-surface: rgba(11, 18, 38, 0.78);
  --page-surface-strong: rgba(9, 16, 32, 0.94);
  --page-surface-soft: rgba(255, 255, 255, 0.05);
  --page-border: rgba(149, 183, 255, 0.14);
  --page-text: #eef3ff;
  --page-text-muted: #9ba8c8;
  --page-shadow: 0 28px 72px rgba(0, 0, 0, 0.22);
  --page-radius: 28px;
  --page-radius-large: 36px;
  --page-accent: #49b8ff;
  --page-accent-soft: rgba(73, 184, 255, 0.16);
  --page-accent-strong: rgba(73, 184, 255, 0.34);
  --page-accent-glow: rgba(73, 184, 255, 0.28);
  --page-hero-overlay: linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.02));
  --page-body-font: 'Rajdhani', sans-serif;
  --page-heading-font: 'Orbitron', sans-serif;

/* ===== Critical extracted rules for music/history (minimal set to restore layout) ===== */
.mh-page { --mh-accent: var(--page-accent); --mh-text: var(--page-text); }
body { background: linear-gradient(180deg, #080f08 0%, #0a1810 50%, #080d08 100%) !important; }
.mh-hero {
  position: relative;
  min-height: 92vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6rem 1.5rem 0;
}
.mh-hero__content { position: relative; z-index: 10; text-align: center; max-width: 860px; padding-bottom: 9rem; }
.mh-hero__title { font-family: var(--page-body-font); font-weight:700;font-size:7rem; color: var(--mh-text); margin: 0 0 2rem; }
.mh-hero__lead { color: var(--page-text-muted); max-width: 600px; margin: 0 auto; }
.mh-split { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
@media (min-width: 801px) { .mh-split { grid-template-columns: 1fr 420px; align-items: center; } }
.mh-split__media img { width: 100%; height: auto; border-radius: 12px; }
.mh-dark-box { background: rgba(6,12,8,0.6); padding: 1.5rem; border-radius: 12px; }
.mh-gallery--trio { display:flex; justify-content:center; align-items:flex-end; gap:2.5rem; }
.mh-gallery--trio .mh-img { flex:1 1 0; max-width:340px; min-width:0; border-radius:14px; object-fit:cover; }
.mh-year { flex: 0 0 auto; align-self: flex-start; }

/* make sure CTA eyebrow removed visual gap doesn't collapse */
.mh-hero__eyebrow { display:none; }

/* small mobile tweaks */
@media (max-width:800px) {
  .mh-hero { padding-top: 3.6rem; }
  .mh-gallery--trio { flex-direction:column; gap:1rem; }
  .mh-gallery--trio .mh-img { max-width:90vw; }
}

/* End critical extracted rules */

/* --- Additional restored rules from original music/history page (layout + visuals) --- */
.mh-img { width: 100%; height: auto; display: block; border-radius: 12px; }
.mh-img-caption { font-size: 0.92rem; color: var(--page-text-muted); margin-top: 0.5rem; }
.mh-chapter { position: relative; padding: 3.25rem 0; border-bottom: 1px solid rgba(0,0,0,0.04); }
.mh-chapter__tag { display:inline-block; font-weight:700; color:var(--page-accent); background:transparent; margin-bottom:0.6rem; }
.mh-chapter__title { font-size: clamp(1.3rem, 3.6vw, 2.25rem); margin: 0 0 1rem; }
.mh-chapter__bg-num { position: absolute; right: 1rem; top: 0.6rem; font-size: 6rem; opacity: 0.03; pointer-events:none; }
.mh-text { color: var(--page-text); line-height:1.65; }
.mh-actions { margin-top: 1rem; }
.mh-wave-divider { width:100%; margin: 1.5rem 0; }
.mh-cta { padding: 3.5rem 1.25rem; text-align:center; background: linear-gradient(180deg, rgba(0,0,0,0.02), transparent); }
.mh-cta__title { font-size: 1.6rem; margin-bottom: 0.6rem; }
.mh-cta__text { color: var(--page-text-muted); margin-bottom: 1rem; }
.c-topbar { position: sticky; top:0; z-index:50; background: var(--page-surface); border-bottom: 1px solid var(--page-border); }

.c-shell { max-width: 1100px; margin: 0 auto; padding: 0 1rem; }
.mh-gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
@media (max-width: 800px) { .mh-gallery { grid-template-columns: 1fr; } }

/* Blobs and story body subtle effects (non-essential animation reduced) */
.mh-hero__blob, .mh-story__blob { opacity: 0.6; filter: blur(80px); }

/* ensure language switcher visual consistency */
.c-language-switcher { display:flex; align-items:center; gap:0.4rem; }
.c-language-switcher__option { border:1px solid rgba(255,255,255,0.04); background:transparent; padding:0.4rem 0.5rem; border-radius:6px; }

/* End restored rules */

/* Trio gallery helper copied from music/history inline styles */
.mh-gallery--trio { display:flex; justify-content: center; align-items: flex-end; gap: 2.5rem; }
.mh-gallery--trio .mh-img { flex: 1 1 0; max-width: 340px; min-width: 0; }
@media (max-width: 800px) {
  .mh-gallery--trio { flex-direction: column; align-items: stretch; gap: 1rem; }
  .mh-gallery--trio .mh-img { max-width: 100%; flex: none; }
}

/* Ensure mh-dark-box + u-w-full behaves consistently without inline styles */
.mh-dark-box.u-w-full { max-width: 100%; margin-left: 0; margin-right: 0; }

/* End trio gallery helper */
  --page-label-font: 'Press Start 2P', monospace;
  --page-pattern: radial-gradient(circle at top, rgba(70, 110, 190, 0.2), transparent 34%), linear-gradient(180deg, #0a1121 0%, #060a15 100%);
}

/* Styles moved from music/history.html <style> block */
/* --- music/history page styles (kept as-is to preserve exact visuals) --- */
 /* (extracted page-level CSS omitted here for brevity) */

/* Responsive gallery trio as flex for equal distribution */
.mh-gallery--trio-flex {
  display: flex !important;
  justify-content: center !important;
  align-items: flex-end !important;
  gap: 2.5rem !important;
}
.mh-gallery--trio-flex .mh-img {
  flex: 1 1 0 !important;
  max-width: 340px !important;
  min-width: 0 !important;
}

/* ================================================================
   MUSIC HISTORY PAGE -- Dark Nature / Green-Blue Palette (moved)
   Extracted from music/history.html <style> block to follow BEM organization
   ================================================================ */

/* NOTE: full page CSS originally contained many rules (hero, story, chapters,
   responsive) — to keep this patch succinct we appended the critical helpers
   and left the original, larger page CSS merged earlier in previous edits.
   If you want the full raw extraction pasted here, I can append it verbatim.
*/


*,
*::before,
*::after {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-height: 100vh;
  color: var(--page-text);
  font-family: var(--page-body-font);
  background: var(--page-pattern);
}

a {
  color: inherit;
  text-decoration: none;
}

img {
  display: block;
  max-width: 100%;
}

iframe {
  display: block;
  width: 100%;
  border: 0;
}

button {
  font: inherit;
}

.c-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.c-page::before,
.c-page::after {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
}

.c-page::before {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent 18%, transparent 82%, rgba(255, 255, 255, 0.04));
  opacity: 0.55;
}

.c-page::after {
  background: radial-gradient(circle at 15% 10%, var(--page-accent-glow), transparent 24%), radial-gradient(circle at 85% 18%, rgba(255, 255, 255, 0.08), transparent 18%);
}

.c-page--pilot {
  --page-surface: rgba(245, 249, 246, 0.72);
  --page-surface-strong: rgba(246, 250, 247, 0.9);
  --page-surface-soft: rgba(255, 255, 255, 0.48);
  --page-border: rgba(56, 104, 84, 0.16);
  --page-text: #183227;
  --page-text-muted: #496759;
  --page-shadow: 0 28px 70px rgba(35, 62, 50, 0.14);
  --page-accent: #2f8a6d;
  --page-accent-soft: rgba(47, 138, 109, 0.14);
  --page-accent-strong: rgba(47, 138, 109, 0.3);
  --page-accent-glow: rgba(165, 216, 193, 0.42);
  --page-heading-font: 'Rajdhani', sans-serif;
  --page-label-font: 'Rajdhani', sans-serif;
  --page-pattern: radial-gradient(circle at top, rgba(133, 202, 174, 0.35), transparent 28%), radial-gradient(circle at bottom right, rgba(224, 237, 221, 0.95), transparent 28%), linear-gradient(180deg, #d5ebe1 0%, #f4f6f0 42%, #e9efe7 100%);
}

.c-page--pilot::before {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.34), transparent 24%, transparent 78%, rgba(65, 121, 97, 0.08));
}

.c-page--pilot::after {
  background: radial-gradient(circle at 12% 14%, rgba(132, 205, 181, 0.36), transparent 22%), radial-gradient(circle at 88% 20%, rgba(255, 220, 175, 0.26), transparent 18%), linear-gradient(180deg, transparent 65%, rgba(101, 156, 125, 0.12));
}

.c-page--journey {
  --page-text: #d8eedd;
  --page-text-muted: #6a9878;
  --page-surface: rgba(12, 30, 18, 0.72);
  --page-surface-strong: rgba(8, 22, 12, 0.94);
  --page-border: rgba(70, 180, 110, 0.14);
  --page-shadow: 0 24px 60px rgba(0, 0, 0, 0.6);
  --page-accent: #42c874;
  --page-accent-soft: rgba(66, 200, 116, 0.12);
  --page-accent-strong: rgba(66, 200, 116, 0.32);
  --page-accent-glow: rgba(66, 200, 116, 0.2);
  --page-hero-overlay: linear-gradient(135deg, rgba(20, 60, 30, 0.15), rgba(10, 30, 50, 0.08));
  --page-heading-font: 'Rajdhani', sans-serif;
  --page-label-font: 'Orbitron', monospace;
  --page-pattern:
    radial-gradient(ellipse at 20% 18%, rgba(12, 65, 45, 0.42), transparent 38%),
    radial-gradient(ellipse at 78% 16%, rgba(8, 45, 90, 0.46), transparent 34%),
    linear-gradient(180deg, #060f0a 0%, #09161e 50%, #060e0a 100%);
}

.c-page--journey::before {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 22%, transparent 78%, rgba(66, 200, 116, 0.08));
}

.c-page--journey::after {
  background:
    radial-gradient(circle at 15% 12%, rgba(66, 200, 116, 0.15), transparent 24%),
    radial-gradient(circle at 82% 14%, rgba(66, 140, 200, 0.16), transparent 24%);
}

/* Lightweight drifting cloud layer for the paraglider world */
.c-page--journey::before {
  inset: -24% -24%;
  background:
    radial-gradient(ellipse 26rem 8.8rem at 10% 22%, rgba(236, 247, 252, 0.15) 0%, rgba(236, 247, 252, 0.07) 45%, transparent 72%),
    radial-gradient(ellipse 22rem 7.6rem at 30% 14%, rgba(236, 247, 252, 0.13) 0%, rgba(236, 247, 252, 0.055) 42%, transparent 69%),
    radial-gradient(ellipse 27rem 9rem at 54% 26%, rgba(229, 242, 249, 0.12) 0%, rgba(229, 242, 249, 0.05) 47%, transparent 72%),
    radial-gradient(ellipse 22rem 7.5rem at 73% 13%, rgba(236, 247, 252, 0.13) 0%, rgba(236, 247, 252, 0.055) 44%, transparent 69%),
    radial-gradient(ellipse 26rem 8.8rem at 94% 24%, rgba(229, 242, 249, 0.11) 0%, rgba(229, 242, 249, 0.045) 46%, transparent 73%);
  background-repeat: no-repeat;
  background-size: 120% 100%, 120% 100%, 120% 100%, 120% 100%, 120% 100%;
  background-position: 6% 0%, 22% 0%, 44% 0%, 66% 0%, 88% 0%;
  opacity: 0.88;
  filter: none;
  animation: c-journey-cloud-pan 28s ease-in-out infinite alternate;
}

.c-page--journey::after {
  inset: 0;
  opacity: 0.8;
  animation: none;
}

@keyframes c-journey-cloud-pan {
  0% {
    background-position: 6% 0%, 22% 0%, 44% 0%, 66% 0%, 88% 0%;
  }
  100% {
    background-position: 16% 0%, 32% 0%, 54% 0%, 76% 0%, 98% 0%;
  }
}

@media (max-width: 1080px) {
  .c-page--journey::before {
    inset: -22% -22%;
    background-size: 132% 100%, 132% 100%, 132% 100%, 132% 100%, 132% 100%;
    animation-duration: 24s;
  }
}

@media (max-width: 720px) {
  .c-page--journey::before {
    inset: -20% -20%;
    background-size: 150% 100%, 150% 100%, 150% 100%, 150% 100%, 150% 100%;
    background-position: 2% 0%, 18% 0%, 40% 0%, 62% 0%, 84% 0%;
    animation-duration: 20s;
  }
}

@media (prefers-reduced-motion: reduce) {
  .c-page--journey::before,
  .c-page--journey::after {
    animation: none;
  }
}

.c-page--journey .c-topbar {
  background: rgba(4, 12, 7, 0.92);
  border-bottom: 1px solid rgba(66, 200, 116, 0.1);
}



.c-page--journey .c-language-switcher {
  border-color: rgba(66, 200, 116, 0.14);
  background: rgba(66, 200, 116, 0.05);
}

.c-page--journey .c-language-switcher__label {
  color: #4a7858;
}

.c-page--journey .c-language-switcher__option {
  color: #c8e8d0;
  border-color: rgba(66, 200, 116, 0.14);
}

.c-page--journey .c-language-switcher__option--is-active {
  background: rgba(66, 200, 116, 0.12);
  border-color: rgba(66, 200, 116, 0.32);
}

.c-page--journey .c-button,
.c-page--journey .c-link-pill {
  background: rgba(66, 200, 116, 0.1);
  border-color: rgba(66, 200, 116, 0.32);
  color: #a0d8b0;
}

.c-page--journey .c-button--ghost,
.c-page--journey .c-link-pill--ghost {
  background: transparent;
  border-color: rgba(66, 200, 116, 0.16);
  color: #9bbfa6;
}

.c-page--journey .c-section {
  position: relative;
}

.c-page--journey .c-mountain-divider {
  width: 100%;
  margin: 0.5rem 0 1.5rem;
  line-height: 0;
  opacity: 0.18;
}

.c-page--journey .c-mountain-divider svg {
  display: block;
  width: 100%;
}

.c-page--music {
  --page-surface: rgba(12, 28, 18, 0.72);
  --page-surface-strong: rgba(8, 22, 12, 0.92);
  --page-surface-soft: rgba(255, 255, 255, 0.04);
  --page-border: rgba(0, 230, 118, 0.18);
  --page-text: #d8f0e0;
  --page-text-muted: #6a9878;
  --page-shadow: 0 28px 72px rgba(4, 14, 8, 0.36);
  --page-accent: #00e676;
  --page-accent-soft: rgba(0, 230, 118, 0.15);
  --page-accent-strong: rgba(0, 230, 118, 0.34);
  --page-accent-glow: rgba(0, 230, 118, 0.24);
  --page-heading-font: 'Orbitron', sans-serif;
  --page-label-font: 'Rajdhani', sans-serif;
  --page-pattern: radial-gradient(circle at 12% 18%, rgba(0, 230, 118, 0.18), transparent 26%), radial-gradient(circle at 82% 16%, rgba(0, 188, 212, 0.2), transparent 24%), radial-gradient(circle at 50% 100%, rgba(0, 0, 255, 0.16), transparent 34%), linear-gradient(135deg, #041208 0%, #06180e 45%, #04100a 100%);
}

.c-page--music::before {
  background: radial-gradient(circle at 20% 14%, rgba(0, 230, 118, 0.06), transparent 14%), radial-gradient(circle at 74% 18%, rgba(0, 188, 212, 0.05), transparent 14%), linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent 24%, transparent 76%, rgba(255, 255, 255, 0.02));
}

.c-page--music::after {
  inset: -30% -22%;
  background:
    radial-gradient(ellipse 30rem 23rem at 18% 24%, rgba(0, 230, 118, 0.2), transparent 65%),
    radial-gradient(ellipse 34rem 24rem at 72% 18%, rgba(0, 188, 212, 0.18), transparent 68%),
    radial-gradient(ellipse 28rem 20rem at 80% 70%, rgba(0, 0, 255, 0.16), transparent 66%),
    radial-gradient(ellipse 30rem 22rem at 30% 82%, rgba(74, 0, 224, 0.14), transparent 68%);
  opacity: 0.75;
  filter: blur(10px);
  animation: c-music-blob-drift 24s ease-in-out infinite alternate;
}

@keyframes c-music-blob-drift {
  0% {
    transform: translate3d(-4%, -3%, 0) scale(1);
  }
  50% {
    transform: translate3d(5%, 2%, 0) scale(1.06);
  }
  100% {
    transform: translate3d(-2%, 6%, 0) scale(1.02);
  }
}

.c-page--dev {
  --page-accent: #00ff88;
  --page-accent-soft: rgba(0, 255, 136, 0.12);
  --page-accent-strong: rgba(0, 255, 136, 0.3);
  --page-accent-glow: rgba(0, 255, 136, 0.2);
}

.c-shell {
  width: min(1180px, calc(100% - 2rem));
  margin: 0 auto;
}







.c-language-switcher {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.35rem;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.05);
}

.c-page--music .c-language-switcher {
  border-radius: 1rem;
}

.c-language-switcher__label {
  padding-inline: 0.55rem;
  color: var(--page-text-muted);
  font-family: var(--page-label-font);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.c-language-switcher__option {
  min-width: 3.25rem;
  padding: 0.65rem 0.85rem;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 999px;
  background: transparent;
  color: var(--page-text);
  font-family: var(--page-label-font);
  font-size: 0.72rem;
  font-weight: 700;
  cursor: pointer;
}

.c-page--music .c-language-switcher__option {
  border-radius: 0.95rem;
}

.c-language-switcher__option--is-active {
  background: var(--page-accent-soft);
  border-color: var(--page-accent-strong);
  box-shadow: 0 0 18px var(--page-accent-soft);
}

.c-hero {
  position: relative;
  padding: 4.75rem 0 2.5rem;
}

.c-hero--split {
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.9fr);
  gap: 1.6rem;
  align-items: stretch;
}

.c-hero__panel,
.c-hero__media,
.c-card,
.c-nav-card,
.c-story-card,
.c-detail-panel,
.c-info-strip,
.c-project-card,
.c-media-frame,
.c-quote-card,
.c-highlight-card,
.c-timeline,
.c-embed-card,
.c-callout,
.c-link-cluster,
.c-mini-card,
.c-schedule-card,
.c-stat-card {
  background: var(--page-hero-overlay), var(--page-surface);
  border: 1px solid var(--page-border);
  border-radius: var(--page-radius);
  box-shadow: var(--page-shadow);
}


.c-hero__panel {
  padding: 2rem;
  background: none !important;
  box-shadow: none !important;
  border: none !important;
}

.c-hero__media {
  position: relative;
  min-height: 24rem;
  overflow: hidden;
  isolation: isolate;
}

.c-hero__media::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(0, 0, 0, 0.18));
  z-index: 1;
}

.c-page--pilot .c-hero__media::before {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(27, 58, 43, 0.08));
}

.c-page--music .c-hero__media::before {
  background: linear-gradient(135deg, rgba(255, 110, 82, 0.12), rgba(66, 30, 149, 0.24));
}

.c-hero__image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.c-hero__media-copy {
  position: absolute;
  inset: auto 1.5rem 1.5rem 1.5rem;
  z-index: 2;
  display: grid;
  gap: 0.7rem;
}

.c-hero__eyebrow,
.c-card__eyebrow,
.c-kicker,
.c-embed-card__eyebrow,
.c-project-card__eyebrow,
.c-timeline__eyebrow,
.c-schedule-card__eyebrow,
.c-highlight-card__eyebrow,
.c-media-frame__eyebrow {
  display: inline-block;
  color: var(--page-accent);
  font-family: var(--page-label-font);
  font-size: 0.76rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.c-hero__title,
.c-card__title,
.c-section__title,
.c-project-card__title,
.c-detail-panel__title,
.c-embed-card__title,
.c-highlight-card__title,
.c-quote-card__title,
.c-media-frame__title,
.c-timeline__title {
  margin: 0;
  font-family: var(--page-heading-font);
  font-size: clamp(1.45rem, 3vw, 2.6rem);
  line-height: 0.98;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.c-page--pilot .c-hero__title,
.c-page--pilot .c-card__title,
.c-page--pilot .c-section__title,
.c-page--pilot .c-project-card__title,
.c-page--pilot .c-detail-panel__title,
.c-page--pilot .c-embed-card__title,
.c-page--pilot .c-highlight-card__title,
.c-page--pilot .c-quote-card__title,
.c-page--pilot .c-media-frame__title,
.c-page--pilot .c-timeline__title {
  letter-spacing: 0.02em;
}

.c-hero__lead,
.c-card__text,
.c-section__text,
.c-project-card__text,
.c-detail-panel__text,
.c-list__text,
.c-nav-card__text,
.c-story-card__text,
.c-highlight-card__text,
.c-embed-card__text,
.c-media-frame__text,
.c-quote-card__text,
.c-callout__text,
.c-mini-card__text,
.c-stat-card__text {
  color: var(--page-text-muted);
  font-size: 1.05rem;
  line-height: 1.6;
}

.c-hero__lead {
  width: min(45rem, 100%);
  margin: 1.15rem 0 0;
  font-size: clamp(1.12rem, 2vw, 1.38rem);
}

.c-hero__actions,
.c-link-cluster {
  display: flex;
  gap: 0.9rem;
  flex-wrap: wrap;
  margin-top: 1.8rem;
}

.c-button,
.c-link-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 11rem;
  padding: 0.95rem 1.25rem;
  border: 1px solid var(--page-accent-strong);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.05);
  color: var(--page-text);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-weight: 700;
  transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, border-color 0.2s ease;
}

.c-page--music .c-button,
.c-page--music .c-link-pill {
  border-radius: 1rem;
}

.c-button:hover,
.c-button:focus-visible,
.c-link-pill:hover,
.c-link-pill:focus-visible {
  transform: translateY(-2px);
  box-shadow: 0 14px 28px rgba(0, 0, 0, 0.16);
  background: var(--page-accent-soft);
}

.c-button--ghost,
.c-link-pill--ghost {
  border-color: rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.03);
}

.c-section {
  padding: 0 0 4rem;
}

.c-section__head {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: end;
  margin-bottom: 1.6rem;
}

.c-card-grid,
.c-project-grid,
.c-stat-grid,
.c-feature-grid,
.c-gallery,
.c-schedule-grid,
.c-mini-grid {
  display: grid;
  grid-template-columns: repeat(12, minmax(0, 1fr));
  gap: 1.2rem;
}

.c-card,
.c-nav-card,
.c-story-card,
.c-project-card,
.c-highlight-card,
.c-mini-card,
.c-schedule-card,
.c-stat-card,
.c-callout,
.c-quote-card,
.c-media-frame,
.c-embed-card {
  padding: 1.55rem;
}

.c-nav-card,
.c-story-card,
.c-project-card,
.c-highlight-card,
.c-mini-card,
.c-schedule-card {
  position: relative;
  overflow: hidden;
}

.c-nav-card::before,
.c-story-card::before,
.c-project-card::before,
.c-highlight-card::before,
.c-schedule-card::before {
  content: '';
  position: absolute;
  inset: auto -16% -18% auto;
  width: 10rem;
  height: 10rem;
  border-radius: 50%;
  background: var(--page-accent-soft);
  filter: blur(10px);
}

.c-nav-card {
  grid-column: span 4;
  min-height: 18rem;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.c-story-card,
.c-project-card {
  grid-column: span 6;
}

.c-highlight-card {
  grid-column: span 3;
}

.c-mini-card,
.c-schedule-card,
.c-stat-card {
  grid-column: span 4;
}

.c-project-card--wide,
.c-media-frame,
.c-embed-card {
  grid-column: span 12;
}

.c-nav-card__meta,
.c-story-card__meta,
.c-project-card__meta {
  color: var(--page-accent);
  font-family: var(--page-label-font);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.c-nav-card__title,
.c-story-card__title,
.c-project-card__title {
  margin: 0.85rem 0 0.7rem;
  font-family: var(--page-heading-font);
  font-size: 1.45rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.c-nav-card__cta,
.c-project-card__cta {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  margin-top: 1.25rem;
  color: var(--page-text);
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.c-project-card__links {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-top: 1.25rem;
}

.c-info-strip {
  padding: 1.25rem 1.4rem;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
}

.c-info-strip__item {
  padding-right: 1rem;
  border-right: 1px solid rgba(255, 255, 255, 0.08);
}

.c-info-strip__item:last-child {
  padding-right: 0;
  border-right: 0;
}

.c-info-strip__label,
.c-stat-card__label {
  display: block;
  margin-bottom: 0.55rem;
  color: var(--page-accent);
  font-family: var(--page-label-font);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.c-info-strip__value,
.c-stat-card__value {
  color: var(--page-text);
  font-size: 1.05rem;
  line-height: 1.5;
}

.c-detail-layout {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.8fr);
  gap: 1.2rem;
}

.c-detail-panel {
  padding: 1.7rem;
}

.c-list {
  display: grid;
  gap: 1rem;
  margin: 1.3rem 0 0;
  padding: 0;
  list-style: none;
}

.c-list__item {
  padding: 1rem 1rem 1rem 1.15rem;
  border-left: 2px solid var(--page-accent-strong);
  border-radius: 1rem;
  background: rgba(255, 255, 255, 0.03);
}

.c-page--pilot .c-list__item {
  background: rgba(255, 255, 255, 0.4);
}

.c-list__title {
  margin: 0 0 0.35rem;
  font-family: var(--page-heading-font);
  font-size: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.c-quote-card {
  display: grid;
  gap: 1rem;
}

.c-quote-card__text {
  margin: 0;
  font-size: clamp(1.35rem, 2vw, 1.75rem);
  line-height: 1.35;
  color: var(--page-text);
}

.c-quote-card__meta {
  color: var(--page-text-muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  font-size: 0.9rem;
}

.c-media-frame {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.75fr);
  gap: 1.2rem;
  align-items: stretch;
}

.c-media-frame__visual {
  position: relative;
  overflow: hidden;
  border-radius: calc(var(--page-radius) - 8px);
  min-height: 20rem;
}

.c-media-frame__visual img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.c-media-frame__copy {
  display: grid;
  align-content: center;
  gap: 0.9rem;
}

.c-timeline {
  padding: 1.7rem;
}

.c-timeline__list {
  position: relative;
  display: grid;
  gap: 1.15rem;
  margin: 1.2rem 0 0;
}

.c-timeline__list::before {
  content: '';
  position: absolute;
  left: 0.8rem;
  top: 0.35rem;
  bottom: 0.35rem;
  width: 1px;
  background: var(--page-accent-strong);
}

.c-timeline__item {
  position: relative;
  padding-left: 2.5rem;
}

.c-timeline__item::before {
  content: '';
  position: absolute;
  left: 0.35rem;
  top: 0.42rem;
  width: 0.9rem;
  height: 0.9rem;
  border-radius: 50%;
  background: var(--page-accent);
  box-shadow: 0 0 0 8px var(--page-accent-soft);
}

.c-timeline__label {
  display: inline-block;
  margin-bottom: 0.35rem;
  color: var(--page-accent);
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.c-timeline__item-title {
  margin: 0;
  font-family: var(--page-heading-font);
  font-size: 1.15rem;
  text-transform: uppercase;
}

.c-timeline__item-text {
  margin: 0.4rem 0 0;
  color: var(--page-text-muted);
  font-size: 1rem;
  line-height: 1.6;
}

.c-embed-card {
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.75fr);
  gap: 1.2rem;
  align-items: center;
}

.c-embed-card__frame {
  overflow: hidden;
  min-height: 23rem;
  border-radius: calc(var(--page-radius) - 8px);
  background: rgba(0, 0, 0, 0.18);
}

.c-embed-card__frame iframe {
  min-height: 23rem;
}

.c-callout {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.c-callout__copy {
  display: grid;
  gap: 0.4rem;
}

.c-page-footer {
  padding: 0 0 3rem;
}

.c-page-footer__text {
  color: var(--page-text-muted);
  text-align: center;
  font-family: var(--page-label-font);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.c-storyline {
  display: grid;
  gap: 1rem;
  margin-top: 1.4rem;
}

.c-story-chapter {
  padding: 1.15rem 1.2rem;
  border: 1px solid var(--page-border);
  border-radius: 1rem;
  background: rgba(255, 255, 255, 0.03);
}

.c-story-chapter__title {
  margin: 0;
  font-family: var(--page-heading-font);
  font-size: 1.05rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.c-story-chapter__pt,
.c-story-chapter__en {
  margin: 0.7rem 0 0;
  color: var(--page-text-muted);
  line-height: 1.55;
}

.c-story-chapter__pt strong,
.c-story-chapter__en strong {
  color: var(--page-text);
}

@media (max-width: 1080px) {
  .c-hero--split,
  .c-detail-layout,
  .c-media-frame,
  .c-embed-card {
    grid-template-columns: 1fr;
  }

  .c-highlight-card {
    grid-column: span 6;
  }
}

@media (max-width: 980px) {

  .c-nav-card,
  .c-story-card,
  .c-project-card,
  .c-highlight-card,
  .c-mini-card,
  .c-schedule-card,
  .c-stat-card {
    grid-column: span 12;
  }

  .c-info-strip {
    grid-template-columns: 1fr;
  }

  .c-info-strip__item {
    padding-right: 0;
    padding-bottom: 1rem;
    border-right: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .c-info-strip__item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .c-callout {
    align-items: stretch;
    flex-direction: column;
  }
}

@media (max-width: 720px) {
  .c-shell {
    width: min(100% - 1rem, 100%);
  }

  .c-topbar__link,
  .c-button,
  .c-link-pill {
    width: 100%;
  }

  .c-language-switcher {
    width: 100%;
    justify-content: center;
  }

  .c-hero {
    padding-top: 3.2rem;
  }

  .c-hero__panel,
  .c-card,
  .c-nav-card,
  .c-story-card,
  .c-project-card,
  .c-highlight-card,
  .c-mini-card,
  .c-schedule-card,
  .c-stat-card,
  .c-detail-panel,
  .c-media-frame,
  .c-embed-card,
  .c-callout,
  .c-quote-card,
  .c-info-strip {
    padding: 1.2rem;
  }

  .c-hero__media,
  .c-media-frame__visual,
  .c-embed-card__frame,
  .c-embed-card__frame iframe {
    min-height: 18rem;
  }
}

 body { background: linear-gradient(180deg, #080f08 0%, #0a1810 50%, #080d08 100%) !important; }
    .c-page--music {
      --mh-accent: #00e676;
      --mh-accent-soft: rgba(0,230,118,0.12);
      --mh-accent-strong: rgba(0,230,118,0.28);
      --mh-accent-glow: rgba(0,230,118,0.18);
      --mh-text: #d8f0e0;
      --mh-text-muted: #6a9878;
      --mh-panel: rgba(12,28,18,0.72);
      --mh-border: rgba(0,230,118,0.14);
      color: var(--mh-text);
      font-family: 'Rajdhani', sans-serif;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* Typography to match history page */
    .c-page--music .c-media-frame__copy h2,
    .c-page--music .c-detail-panel__title,
    .c-page--music h1,
    .c-page--music h2,
    .c-page--music h3,
    .c-page--music h4 {
      font-family: 'Rajdhani', sans-serif;
      font-weight: 700;
      font-size: clamp(1.4rem, 2.2vw, 2rem);
      line-height: 1.05;
      color: var(--mh-text);
      margin: 0 0 0.6rem;
    }

    .c-page--music p,
    .c-page--music .c-card__text,
    .c-page--music .c-detail-panel__text {
      font-family: 'Rajdhani', sans-serif;
      font-weight: 300;
      font-size: clamp(0.98rem, 1.4vw, 1.05rem);
      line-height: 1.6;
      color: var(--mh-text);
      margin: 0 0 1rem;
    }

    .c-page--music .c-media-frame { gap: 2rem; align-items: stretch; display:grid; grid-template-columns: 1fr 1fr; }
    @media (max-width: 900px) { .c-page--music .c-media-frame { grid-template-columns: 1fr; } }

    /* single-column variant for splits where visual is removed */
    .mh-split--single { grid-template-columns: 1fr !important; }

    .c-page--music .c-media-frame__visual img { height: 18rem; object-fit: cover; border-radius: 12px; box-shadow: 0 22px 54px rgba(6,12,8,0.6); }
    @media (min-width:1200px) { .c-page--music .c-media-frame__visual img { height: 22rem; } }

    .c-page--music .c-detail-panel { background: var(--mh-panel); border: 1px solid var(--mh-border); padding: 1.5rem; border-radius: 12px; color: var(--mh-text); }
    .c-page--music .c-detail-panel__title { color: var(--mh-text); font-size: 1.25rem; }

    .c-page--music .c-info-strip { display:flex; gap:1rem; }
    .c-page--music .c-info-strip__label { color: var(--mh-text-muted); }

    /* Green background blobs + stars (subtle, tuned to history) */
    .music-bg-blob { position: absolute; border-radius: 50%; pointer-events: none; filter: blur(100px); opacity: 0.7; will-change: transform, opacity; }
    .music-bg-blob--a { width: 45vw; height: 45vw; top: -10%; left: -12%; background: radial-gradient(circle, rgba(0,230,118,0.22) 0%, transparent 70%); animation: mh-blob-drift-1 18s ease-in-out infinite alternate; z-index:0; }
    .music-bg-blob--b { width: 38vw; height: 38vw; top: 15%; right: -8%; background: radial-gradient(circle, rgba(0,188,212,0.2) 0%, transparent 70%); animation: mh-blob-drift-2 22s ease-in-out infinite alternate; z-index:0; }
    .music-bg-blob--c { width: 30vw; height: 30vw; bottom: 10%; left: 30%; background: radial-gradient(circle, rgba(74,0,224,0.16) 0%, transparent 70%); animation: mh-blob-drift-3 26s ease-in-out infinite alternate; z-index:0; }
    @keyframes mh-blob-drift-1 { 0%{transform:translate(0,0) scale(1);opacity:.6}33%{transform:translate(8vw,5vh) scale(1.12);opacity:.75}66%{transform:translate(-3vw,10vh) scale(.95);opacity:.55}100%{transform:translate(5vw,-3vh) scale(1.08);opacity:.7} }
    @keyframes mh-blob-drift-2 { 0%{transform:translate(0,0) scale(1);opacity:.5}33%{transform:translate(-6vw,8vh) scale(1.1);opacity:.7}66%{transform:translate(4vw,-4vh) scale(.92);opacity:.45}100%{transform:translate(-5vw,6vh) scale(1.06);opacity:.65} }
    @keyframes mh-blob-drift-3 { 0%{transform:translate(0,0) scale(1);opacity:.45}33%{transform:translate(6vw,-6vh) scale(1.14);opacity:.6}66%{transform:translate(-5vw,3vh) scale(.9);opacity:.4}100%{transform:translate(3vw,8vh) scale(1.05);opacity:.55} }

    .music-stars { position: absolute; inset: 0; z-index: 1; pointer-events: none; background-image: radial-gradient(circle, rgba(255,255,255,0.85) 1px, transparent 1px), radial-gradient(circle, rgba(255,255,255,0.55) 1px, transparent 1px), radial-gradient(circle, rgba(200,240,220,0.5) 1px, transparent 1px); background-size: 220px 220px, 170px 170px, 310px 310px; background-position: 0 0, 80px 50px, 140px 90px; opacity: 0.25; }

    /* Ensure content sits above decor */
    .c-page--music > main, .c-page--music header, .c-page--music footer { position: relative; z-index: 10; }

    /* Add top margin to the first content block */
    .c-page--music .c-section:first-of-type { margin-top: 64px; }

    /* Make detail layout full-width on this page so the last block isn't narrow */
    .c-page--music .c-detail-layout { grid-template-columns: 1fr !important; }
    .c-page--music .c-detail-panel { width: 100%; }

    /* Flow-like block styles (from flow-arts-experience) to match layout and visuals */
    .mh-hero { position: relative; min-height: 52vh; display: flex; align-items: center; padding: 4rem 1.5rem; }
    .mh-hero__inner { display:flex; gap:2rem; align-items:center; width:100%; max-width:1200px; margin:0 auto; }
    .mh-hero__inner { position: relative; z-index: 10 }
    .mh-hero__copy { flex:1 }
    .mh-title { font-family: 'Rajdhani', sans-serif; font-size: clamp(2rem, 5vw, 3.6rem); color: #e8f5ea; margin:0 0 0.8rem }
    .mh-lead { color:var(--mh-text-muted); max-width:640px }

    /* Flow-specific hero: center copy and enlarge title */
    .mh-hero--flow { margin: 0 !important; padding: 0 !important; }
    .mh-hero--flow .mh-hero__inner { flex-direction: column; text-align: center; gap: 1rem }
    .mh-hero--flow .mh-hero__copy { width: 100%; }
    .mh-hero--flow .mh-title { font-size: clamp(3.9rem, 9vw, 7.2rem); }
    .mh-hero--flow .mh-lead { margin: 0 auto; max-width: 820px }

    .mh-chapters { max-width:1200px; margin:2.5rem auto; padding:0 1.5rem }
    .mh-chapter { padding: 2rem 0; border-bottom: 1px solid rgba(0, 230, 118, 0.03); }
    .mh-chapter__title { font-family: 'Rajdhani', sans-serif; font-size: clamp(1.4rem, 3.5vw, 2rem); font-weight:700; color:#c0e0c8; margin:0 0 1rem }

    .mh-split { display:grid; grid-template-columns:1fr 1fr; gap:2.5rem; align-items:center }
    .mh-split__text { background: rgba(8,40,20,0.45); padding:1.4rem; border-left:3px solid rgba(0,230,118,0.35); border-radius:10px; color:#c8f0d8 }
    .mh-split__media iframe, .mh-split__media img { width:100%; border-radius:10px }

    .mh-img-caption { font-family: 'Orbitron', sans-serif; font-size: 0.55rem; letter-spacing: 0.22em; text-transform: uppercase; color: #3a6848; text-align:center; margin-top:0.6rem }
    .mh-cta { display:inline-block; margin-top:0.8rem; padding:0.5rem 0.8rem; background:var(--mh-accent); color:#05210a; border-radius:8px; font-weight:700; text-decoration:none }

